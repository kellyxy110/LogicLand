# LogicLand database connection.
#
# On Vercel these three are injected automatically by the Neon integration.
# For LOCAL development, copy this to `.env` and fill in your values. Pointing
# all of them at your local docker Postgres (`docker compose up -d db`) is fine.

# Pooled connection used at RUNTIME by Prisma. On Neon it carries
# `?pgbouncer=true` so prepared statements are disabled (required for PgBouncer
# transaction pooling). Locally this can be the same as the direct URL.
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/logicland?schema=public"

# Direct (unpooled) connection used only by migrations / `prisma db push`.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/logicland?schema=public"

# Legacy alias — some scripts/tools still read DATABASE_URL. Keep it in sync
# with DATABASE_URL_UNPOOLED for local use.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logicland?schema=public"
