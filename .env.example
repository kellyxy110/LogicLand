# Root env template — shared reference. Each app also has its own .env.example.
# Copy the relevant vars into apps/web/.env.local and logicland-engine/.env.

DATABASE_URL=postgresql://logicland:logicland@localhost:5432/logicland
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI provider (engine-side; OpenAI-compatible)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
