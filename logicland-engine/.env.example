# LogicLand Intelligence Engine — environment template
# Copy to .env and fill in. NEVER commit .env.

# --- Core ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- API ---
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# --- Database (engine-owned analytics / derived data) ---
DATABASE_URL=postgresql+asyncpg://logicland:logicland@localhost:5432/logicland

# --- AI provider (OpenAI-compatible; never hardcoded in code) ---
# Two-lane strategy — see docs/decision.md ADR-009:
#   * Production / child-facing tutor  -> a zero-data-retention provider (below).
#   * Dev / staging / content-gen only -> a free OpenAI-compatible model is fine.
# Switching providers is CONFIG ONLY; call sites never change (ADR-003).
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1200
LLM_CHILD_SAFETY_ENABLED=true

# --- Dev/staging alternative: OpenRouter (free tier) ---
# Uncomment on a NON-production deploy to trial a free model for quiz/worksheet
# generation. Free tiers are rate-limited, may retain prompts, and give no uptime
# guarantee — never point the live child-facing tutor at them. Barred: any
# minimal-guardrail / "uncensored" model. Rotate keys; keep them in env only.
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...            # a freshly rotated OpenRouter key
# LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
