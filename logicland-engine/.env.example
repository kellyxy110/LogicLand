# LogicLand Intelligence Engine — environment template
# Copy to .env and fill in. NEVER commit .env.

# --- Core ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- API ---
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# --- Database (engine-owned analytics / derived data) ---
DATABASE_URL=postgresql+asyncpg://logicland:logicland@localhost:5432/logicland

# --- AI provider (OpenAI-compatible; never hardcoded in code) ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1200
LLM_CHILD_SAFETY_ENABLED=true
