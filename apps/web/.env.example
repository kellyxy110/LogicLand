# LogicLand Web — environment template. Copy to .env.local (never commit).
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
DATABASE_URL=postgresql://logicland:logicland@localhost:5432/logicland

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Storage (swappable provider — see packages/shared storage abstraction)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=
UPLOADTHING_TOKEN=
